+  `is_read` TINYINT DEFAULT 0 COMMENT '是否已读：0-未读，1-已读',
+  `create_time` DATETIME DEFAULT CURRENT_TIMESTAMP COMMENT '创建时间',
+  PRIMARY KEY (`id`),
+  KEY `idx_from_user` (`from_user_id`, `from_user_type`),
