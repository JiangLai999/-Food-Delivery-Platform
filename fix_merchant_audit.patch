+  KEY `idx_user_id` (`user_id`),
+  KEY `idx_food_id` (`food_id`),
+  KEY `idx_merchant_id` (`merchant_id`)
+) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_unicode_ci COMMENT='购物车项表';
+
+-- 用户收藏表（商家收藏）
+CREATE TABLE `user_favorite` (
